# API Configuration

# Local backend — use http:// not https:// (Node on :5001 is plain HTTP; https causes ERR_SSL_PROTOCOL_ERROR)
# EXPO_PUBLIC_API_URL=http://localhost:5001/api

# Deployed backend (HTTPS)
# EXPO_PUBLIC_API_URL=https://your-app.up.railway.app/api

# Development: physical device only — hostname/IP only (no https://, no /api path)
# EXPO_PUBLIC_API_HOST=
